# ─────────────────────────────────────────────────────────────────────────────
# Melting Moments Ecommerce — Production Environment Template
# Copy to .env and fill in all values before running docker compose prod.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=mm_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=mm_ecommerce

# ── Umami Analytics DB ─────────────────────────────────────────────────────────
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=CHANGE_ME_umami_password
UMAMI_DB_NAME=umami
# Generate: openssl rand -hex 32
UMAMI_APP_SECRET=CHANGE_ME_random_64_char_secret
# Set after creating site in Umami dashboard
UMAMI_WEBSITE_ID=

# ── API / FastAPI ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_random_secret_key
ENVIRONMENT=production
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://meltingmomentscakes.com,https://admin.meltingmomentscakes.com

# ── Stripe ─────────────────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# From https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# From https://dashboard.stripe.com/apikeys (used in frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ── Resend (Email) ─────────────────────────────────────────────────────────────
# From https://resend.com/api-keys
RESEND_API_KEY=re_CHANGE_ME
FROM_EMAIL=noreply@meltingmomentscakes.com

# ── Cloudflare R2 (Object Storage) ────────────────────────────────────────────
# From Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=mm-media
# Public URL for your R2 bucket (custom domain or r2.dev subdomain)
R2_PUBLIC_URL=https://media.meltingmomentscakes.com

# ── Next.js Frontend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.meltingmomentscakes.com
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.meltingmomentscakes.com/script.js

# ── Backups (optional GCS) ─────────────────────────────────────────────────────
# Leave empty to use local backups only.
# The VM's attached service account must have the Storage Object Creator role.
# See: https://cloud.google.com/storage/docs/access-control/iam-roles
BACKUP_GCS_BUCKET=
