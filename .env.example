# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=mm_user
POSTGRES_PASSWORD=mm_password
POSTGRES_DB=mm_ecommerce
DATABASE_URL=postgresql+asyncpg://mm_user:mm_password@localhost:5432/mm_ecommerce

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-a-long-random-string-here

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
# Production example:
# CORS_ORIGINS=["https://meltingmomentscakes.com", "https://admin.meltingmomentscakes.com"]

# ─── Allowed Hosts ───────────────────────────────────────────────────────────
ALLOWED_HOSTS=["*"]
# Production example:
# ALLOWED_HOSTS=["meltingmomentscakes.com", "api.meltingmomentscakes.com"]

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=orders@meltingmomentscakes.com

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=mm-ecommerce
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://media.meltingmomentscakes.com

# ─── Tabby ───────────────────────────────────────────────────────────────────
TABBY_API_KEY=
TABBY_PUBLIC_KEY=
TABBY_MERCHANT_CODE=

# ─── Tamara ──────────────────────────────────────────────────────────────────
TAMARA_API_KEY=
TAMARA_API_URL=https://api.tamara.co

# ─── Frontend URLs ───────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── Umami Analytics ─────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
UMAMI_APP_SECRET=change-me-in-production-to-a-random-secret
