NEXT_PUBLIC_SITE_URL=https://meltingmomentscakes.com
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Production: NEXT_PUBLIC_API_URL=https://api.meltingmomentscakes.com/api/v1

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar

# ─── Umami Cloud Analytics (optional) ────────────────────────────────────────
# Leave empty to disable client-side analytics tracking.
# Website ID from: https://cloud.umami.is/settings/websites
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=/umami/script.js

# ─── Google Maps (optional) ──────────────────────────────────────────────────
# Required for the location pin selector on address forms.
# Enable: Maps JavaScript API + Places API (New) in Google Cloud Console.
# Map ID: create one at console.cloud.google.com/google/maps-apis/studio/maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# Leave empty to disable error tracking.
# DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
