# Dev: relative path — Next.js proxies /api/v1/* to NEXT_PRIVATE_API_HOST to keep cookies same-origin.
# Prod: set to the absolute HTTPS API URL.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PRIVATE_API_HOST=http://localhost:8000
# Production: NEXT_PUBLIC_API_URL=https://api.meltingmomentscakes.com/api/v1

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# Leave empty to disable error tracking.
# DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
