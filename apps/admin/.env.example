# Always use the relative path — the Next.js proxy keeps cookies same-origin.
# The admin (vercel.app) and API (meltingmomentscakes.com) are cross-site: SameSite=Lax cookies
# are NOT sent on cross-site JS fetch calls, so using an absolute URL here causes 401 on every request.
NEXT_PUBLIC_API_URL=/api/v1
# Dev: point to local FastAPI. Prod (Vercel): set to https://api.meltingmomentscakes.com
NEXT_PRIVATE_API_HOST=http://localhost:8000

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# Leave empty to disable error tracking.
# DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
