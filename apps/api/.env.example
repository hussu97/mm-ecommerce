# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
# Production: APP_ENV=production

# ─── Nginx ───────────────────────────────────────────────────────────────────
# Set to true once SSL certificates are issued (Step 7 in PRODUCTION.md)
USE_SSL=false

# ─── Database ────────────────────────────────────────────────────────────────
# Individual vars required by docker-compose.prod.yml to initialise the Postgres container
POSTGRES_USER=mm_user
POSTGRES_PASSWORD=mm_password
POSTGRES_DB=mm_ecommerce
DATABASE_URL=postgresql+asyncpg://mm_user:mm_password@localhost:5432/mm_ecommerce
# Production: DATABASE_URL=postgresql+asyncpg://<user>:<password>@postgres:5432/<db>

# ─── Redis (caching) ─────────────────────────────────────────────────────────
# Leave empty to disable caching (API will run without it).
REDIS_URL=redis://localhost:6379/0
# Production: REDIS_URL=redis://redis:6379/0

# ─── Security ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_EXPIRE_MINUTES=60

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# Production: CORS_ORIGINS=["https://meltingmomentscakes.com","https://admin.meltingmomentscakes.com"]

# ─── Allowed Hosts ───────────────────────────────────────────────────────────
ALLOWED_HOSTS=["*"]
# Production: ALLOWED_HOSTS=["api.meltingmomentscakes.com"]

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
FROM_EMAIL=orders@meltingmomentscakes.com

# ─── Cloudflare R2 (object storage) ──────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=xxx
CLOUDFLARE_R2_SECRET_KEY=xxx
CLOUDFLARE_R2_BUCKET=melting-moments-cakes
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://media.meltingmomentscakes.com

# ─── Tabby (BNPL) ────────────────────────────────────────────────────────────
TABBY_API_KEY=xxx
TABBY_PUBLIC_KEY=xxx
TABBY_MERCHANT_CODE=xxx

# ─── Tamara (BNPL) ───────────────────────────────────────────────────────────
TAMARA_API_KEY=xxx
TAMARA_API_URL=https://api.tamara.co

# ─── Frontend URLs (used in email templates) ─────────────────────────────────
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# Production: WEB_URL=https://meltingmomentscakes.com
# Production: ADMIN_URL=https://admin.meltingmomentscakes.com

# ─── Umami Cloud Analytics (optional) ────────────────────────────────────────
# Leave empty to disable traffic metrics on the analytics dashboard.
# Create an API key at: https://cloud.umami.is/settings/api-keys
UMAMI_API_KEY=
UMAMI_WEBSITE_ID=
